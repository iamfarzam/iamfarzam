# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key-min-50-chars
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=False

# Database
DATABASE_URL=postgres://portfolio:change-me-strong-postgres-password@postgres:5432/portfolio
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me-strong-postgres-password

# Django Security
ALLOWED_HOSTS=example.com,www.example.com,localhost,127.0.0.1,backend,nginx
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Frontend
NEXT_PUBLIC_SITE_TITLE=Portfolio
NEXT_PUBLIC_API_URL=https://example.com/api/v1
INTERNAL_API_URL=http://backend:8000/api/v1
NEXT_PUBLIC_SITE_URL=https://example.com
# API cache: 0 or no-store = no cache, or seconds to revalidate (e.g. 60, 3600)
NEXT_PUBLIC_REVALIDATE=0

# Email notifications (optional — leave CONTACT_NOTIFY_EMAIL blank to disable)
# CONTACT_NOTIFY_EMAIL=you@example.com
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=app-password-here
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=you@example.com

# S3-compatible Media Storage (optional — leave S3_BUCKET_NAME blank for local storage)
# Works with Contabo, AWS, MinIO, Wasabi, etc.
# S3_BUCKET_NAME=your-bucket-name
# S3_ENDPOINT_URL=https://eu2.contabostorage.com
# S3_REGION=default
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_CUSTOM_DOMAIN=your-bucket-name.eu2.contabostorage.com
# S3_DEFAULT_ACL=private
# S3_QUERYSTRING_AUTH=True

# Gunicorn (low-memory server defaults)
GUNICORN_WORKERS=1
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
